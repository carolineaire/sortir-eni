{% extends 'base.html.twig' %}

{% block title %}Ajouter un lieu{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/creer-lieu.css">
{% endblock %}

{% block body %}
    <div class="fluid-container">
        <h1 class="page-title">Ajouter un lieu</h1>

        <div class="form-card">
            {{ form_start(form) }}
            {{ form_widget(form) }}

            <div class="submit-container">
                <button class="btn-primary">Enregistrer</button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

{% endblock %}
