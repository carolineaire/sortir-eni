{% extends 'base.html.twig' %}

{% block title %}Modifier mon Profil{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/edit.css">
{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card shadow-sm edit-card">
                    <div class="card-body p-5">

                        <h2 class="text-center mb-4 edit-title">Modifier mon profil</h2>

                        {{ form_start(editProfilForm, {'attr': {'novalidate': 'novalidate'}}) }}

                        <!-- Pseudo -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.pseudo, 'Pseudo') }}
                            {{ form_widget(editProfilForm.pseudo, {'attr': {'class': 'form-control edit-input'}}) }}
                            {{ form_errors(editProfilForm.pseudo) }}
                        </div>

                        <!-- Prenom -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.prenom, 'Prénom') }}
                            {{ form_widget(editProfilForm.prenom, {'attr': {'class': 'form-control edit-input'}}) }}
                            {{ form_errors(editProfilForm.prenom) }}
                        </div>

                        <!-- Nom -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.nom, 'Nom') }}
                            {{ form_widget(editProfilForm.nom, {'attr': {'class': 'form-control edit-input'}}) }}
                            {{ form_errors(editProfilForm.nom) }}
                        </div>

                        <!-- Telephone -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.telephone, 'Téléphone') }}
                            {{ form_widget(editProfilForm.telephone, {'attr': {'class': 'form-control edit-input', 'type': 'tel'}}) }}
                            {{ form_errors(editProfilForm.telephone) }}
                        </div>

                        <!-- Email -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.email, 'Email') }}
                            {{ form_widget(editProfilForm.email, {'attr': {'class': 'form-control edit-input', 'type': 'email'}}) }}
                            {{ form_errors(editProfilForm.email) }}
                        </div>

                        <!-- Ville de rattachement -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.noSites, 'Ville de rattachement') }}
                            {{ form_widget(editProfilForm.noSites, {'attr': {'class': 'form-select edit-input'}}) }}
                            {{ form_errors(editProfilForm.noSites) }}
                        </div>

                        <!-- Mot de passe actuel -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.currentPassword, 'Mot de passe actuel') }}
                            {{ form_widget(editProfilForm.currentPassword, {'attr': {'class': 'form-control edit-input', 'type': 'password'}}) }}
                            {{ form_errors(editProfilForm.currentPassword) }}
                        </div>

                        <!-- Nouveau mot de passe et confirmation (RepeatedType) -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.plainPassword.first, 'Nouveau mot de passe') }}
                            {{ form_widget(editProfilForm.plainPassword.first, {'attr': {'class': 'form-control edit-input'}}) }}
                            <small class="form-text text-muted">Minimum 8 caractères</small>
                            {{ form_errors(editProfilForm.plainPassword.first) }}
                        </div>

                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.plainPassword.second, 'Confirmer le mot de passe') }}
                            {{ form_widget(editProfilForm.plainPassword.second, {'attr': {'class': 'form-control edit-input'}}) }}
                            {{ form_errors(editProfilForm.plainPassword.second) }}
                        </div>

                        <!-- Image -->
                        <div class="mb-3 form-item">
                            {{ form_label(editProfilForm.userPicture, 'Image') }}
                            {{ form_widget(editProfilForm.userPicture, {'attr': {'class': 'form-select edit-input'}}) }}
                            {{ form_errors(editProfilForm.userPicture) }}
                        </div>

                        <hr class="my-4">

                        <!-- Boutons d'action -->
                        <div class="d-flex gap-2 edit-actions">
                            <button type="submit" class="btn btn-primary edit-btn flex-grow-1">
                                <i class="fas fa-save"></i> Mettre à jour
                            </button>
                            <a href="{{ path('app_profil') }}" class="btn btn-secondary edit-btn flex-grow-1">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                        </div>

                        {{ form_end(editProfilForm) }}

                    </div>
                </div>

            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script type="module" src="{{ asset('js/modifier-profil.js') }}"></script>
{% endblock %}
