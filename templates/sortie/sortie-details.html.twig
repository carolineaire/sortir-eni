{% extends 'base.html.twig' %}

{% block title %}Sortie.com{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/sortie.css">
{% endblock %}

{% block body %}

    {# Messages d'erreurs, d'avertissement ou de succès #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Bloc détails de la sortie avec toutes les informations #}
    <div class="sortie-card">

        <h1 class="sortie-title">{{ sortie.nom }}</h1>

        <div class="sortie-grid">

            {# COLONNE GAUCHE #}
            <div class="sortie-section">
                <div><strong>Date et heure :</strong> {{ sortie.dateDebut|date('d/m/Y H:i') }}</div>
                <div><strong>Date limite :</strong> {{ sortie.dateCloture|date('d/m/Y') }}</div>
                <div><strong>Places :</strong> {{ sortie.nbInscriptionMax - sortie.inscriptions|length}}</div>
                <div><strong>Durée :</strong> {{ sortie.duree }} heures</div>
                <div><strong>Organisateur :</strong> 
                    <a class="text-link" href="profil/{{ sortie.organisateur.id }}">
                        {{ sortie.organisateur.prenom }} {{ sortie.organisateur.nom|slice(0,1) }}.
                    </a>
                </div>
                <div class="description">
                    <strong>Description :</strong><br>
                    {{ sortie.description }}
                </div>
            </div>

            {# COLONNE DROITE #}
            <div class="sortie-section">
                <div><strong>Ville :</strong> {{ sortie.noLieux.noVilles.nomVille }}</div>
                <div><strong>Lieu :</strong> {{ sortie.noLieux.nomLieu }}</div>
                <div><strong>Rue :</strong> {{ sortie.noLieux.rue }}</div>
                <div><strong>Code postal :</strong> {{ sortie.noLieux.noVilles.cpo }}</div>
                <div><strong>Latitude :</strong> {{ sortie.noLieux.latitude }}</div>
                <div><strong>Longitude :</strong> {{ sortie.noLieux.longitude }}</div>
            </div>

        </div>

        {# Bontons d'action et badges d'état #}
        <div class="sortie-actions">

            {# Sortie annulée #}
            {% if sortie.noEtats.id == 5 %}
                <span class="badge bg-secondary">Cette activité a été annulée</span>
                {% if sortie.noEtats.id == 5 and sortie.motifAnnulation %}
                    <p class="cancelled">
                        <strong>Motif d'annulation :</strong> {{ sortie.motifAnnulation }}
                    </p>
                {% endif %}

                {# Sortie créée - Option publiée & modifier disponible (seulement pour les admins & l'organisateur) #}
            {% elseif sortie.noEtats.id == 1 %}
                {% if app.user and (app.user.id == sortie.organisateur.id or is_granted('ROLE_ADMIN')) %}
                    <a href="{{ path('sortie_publier', { id: sortie.id, redirect: 'detail' }) }}"
                       class="action-btn btn-success"
                       onclick="return confirm('Publier cette sortie ?');">
                        Publier
                    </a>
                    <a href="{{ path('sortie_edit', { id: sortie.id }) }}"
                       class="action-btn btn-warning">
                        Modifier la sortie
                    </a>
                {% endif %}

                {# Sortie Cloturée - Les inscriptions sont fermées #}
            {% elseif sortie.noEtats.id == 3 %}
                <span class="badge bg-danger">Inscription clôturée</span>

                {# Sortie en cours (début de la sortie + durée) #}
            {% elseif sortie.noEtats.id == 4 %}
                <span class="badge bg-success">Activité en cours</span>

                {# Sortie passée (après début de la sortie + durée) #}
            {% elseif sortie.noEtats.id == 6 %}
                <span class="badge bg-primary">Activité terminée</span>

                {# Sortie archivée (1 mois après la fin de la sortie) #}
            {% elseif sortie.noEtats.id == 7 %}
                <span class="badge bg-warning">Archivée</span>

                {# Sortie ouverte - Options inscriptions, désinscription, modifiée, annulation disponnible (visible par tout les participants) #}
            {% else %}
                {% if app.user %}

                    {% set placesRestantes = sortie.nbInscriptionMax - sortie.inscriptions|length %}
                    {% set inscrit = sortie.estInscrit(app.user) %}

                    {# Si sortie complète, le btn inscription n'est plus disponible (et desinscription seulement pour les inscrits) #}
                    {% if inscrit %}
                        <a href="{{ path('sortie_desinscription', { id: sortie.id, redirect: 'detail' }) }}"
                        class="action-btn danger-detail"
                        onclick="return confirm('Voulez-vous vraiment vous désinscrire ?');">
                            Se désinscrire
                        </a>

                    {% elseif placesRestantes > 0 %}
                        <a href="{{ path('sortie_inscription', { id: sortie.id, redirect: 'detail' }) }}"
                        class="action-btn success-detail">
                            S'inscrire
                        </a>
                    {% endif %}

                {% endif %}

                {% if app.user and (app.user.id == sortie.organisateur.id or is_granted('ROLE_ADMIN')) %}
                    <a href="{{ path('sortie_edit', { id: sortie.id }) }}"
                       class="action-btn btn-warning">
                        Modifier la sortie
                    </a>
                    <a href="{{ path('sortie_annuler', { id: sortie.id, redirect: 'detail' }) }}"
                       class="action-btn outline-danger"
                       data-bs-toggle="modal" data-bs-target="#annulerModal{{ sortie.id }}"
                       onclick="return confirm('Voulez-vous vraiment annuler cette sortie ?');">
                        Annuler la sortie
                    </a>
                {% endif %}
            {% endif %}
        </div>
    </div>

    {# Bloc liste des participants inscrits à la sortie (pas disponible si pas publiée ou si annulée) #}
    {% if sortie.noEtats.id != 1 %}
        <div class="participants-card">

            <h3>Participants inscrits</h3>

       <div class="participants-list">

            {# Afficher l'organisateur en premier #}
            <a href="{{ path('app_profil_user', { id: sortie.organisateur.id }) }}"
            class="participant-row-link">
                <div class="participant-row">
                    <span class="pseudo">{{ sortie.organisateur.pseudo }}</span>
                    <span class="name">{{ sortie.organisateur.prenom }} {{ sortie.organisateur.nom }}</span>
                </div>
            </a>

            {# Boucle sur les inscriptions #}
            {% if sortie.inscriptions|length > 0 %}
                {% for inscription in sortie.inscriptions %}
                    {# Ne pas afficher l'organisateur à nouveau #}
                    {% if inscription.noParticipants.id != sortie.organisateur.id %}
                        <a href="{{ path('app_profil_user', { id: inscription.noParticipants.id }) }}"
                        class="participant-row-link">
                            <div class="participant-row">
                                <span class="pseudo">{{ inscription.noParticipants.pseudo }}</span>
                                <span class="name">{{ inscription.noParticipants.prenom }} {{ inscription.noParticipants.nom }}</span>
                            </div>
                        </a>
                    {% endif %}
                {% endfor %}
            {% else %}
                <div class="no-participant">
                    Aucun participant inscrit
                </div>
            {% endif %}

        </div>
    {% endif %}

    <div class="back-button">
        <a href="{{ path('app_sortie') }}" class="back-home-btn">
            ← Retour à la liste
        </a>
    </div>

    {# Modal pour le motif d'annulation #}
    <div class="modal fade" id="annulerModal{{ sortie.id }}" tabindex="-1" aria-labelledby="annulerModalLabel{{ sortie.id }}" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" action="{{ path('sortie_annuler', { id: sortie.id }) }}">
                    <div class="modal-header">
                        <h5 class="modal-title" id="annulerModalLabel{{ sortie.id }}">Motif d'annulation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="motifAnnulation{{ sortie.id }}" class="form-label">Veuillez indiquer un motif</label>
                            <textarea class="form-control" name="motifAnnulation" id="motifAnnulation{{ sortie.id }}" rows="3" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-danger">Confirmer l'annulation</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script type="module" src="{{ asset('js/message.js') }}"></script>
{% endblock %}
