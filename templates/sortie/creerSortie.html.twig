
{% extends 'base.html.twig' %}

{% block title %}Créer une sortie{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/sortie.css">
{% endblock %}

{% block body %}

    <div class="fluid-container">

        <h1 class="page-title">Créer une sortie</h1>

        <div class="form-card">
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}

            {{ form_start(sortieForm) }}
            <div class="form-check">
                {{ form_widget(sortieForm.isPrivate) }}
                {{ form_label(sortieForm.isPrivate) }}
            </div>

            <div class="invites-card mb-2">
                <div id="invites-list" 
                class="{% if not sortieForm.vars.data.isPrivate %}hidden{% endif %}">
                    {% for invite in sortieForm.invites %}
                        <div class="invite-item">
                            {{ form_widget(invite) }}
                            {{ form_label(invite) }}
                        </div>
                    {% endfor %}
                </div>
            </div>

            <section class="form-section mt-3">
                <h2>Informations générales</h2>

                <div class="grid-2">
                    {{ form_row(sortieForm.nom) }}
                    {{ form_row(sortieForm.nbInscriptionMax) }}
                </div>

                <div class="grid-2">
                    {{ form_row(sortieForm.dateDebut) }}
                    {{ form_row(sortieForm.dateCloture) }}
                </div>

                <div class="grid-2">
                    {{ form_row(sortieForm.duree) }}
                </div>

                {{ form_row(sortieForm.description) }}
            </section>

            <section class="form-section">
                <h2>Localisation</h2>

                <div class="grid-3">
                    {{ form_row(sortieForm.villeOrganisatrice) }}
                    {{ form_row(sortieForm.noVilles) }}

                    <div class="field-with-button">
                        {{ form_row(sortieForm.noLieux) }}
                        <a href="{{ path('lieu_new') }}" target="_blank" class="btn-add-lieu">+</a>
                    </div>
                </div>

                <div class="grid-2">
                    {{ form_row(sortieForm.rue) }}
                    {{ form_row(sortieForm.codePostal) }}
                </div>

                <div class="grid-2">
                    {{ form_row(sortieForm.latitude) }}
                    {{ form_row(sortieForm.longitude) }}
                </div>
            </section>

            <div class="submit-container">
                {{ form_widget(sortieForm.enregistrer) }}
                {{ form_widget(sortieForm.publier) }}

                <a href="{{ path('app_sortie') }}" class="btn-primary ">
                    Annuler
                </a>

            </div>

            {{ form_end(sortieForm) }}
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script type="module" src="{{ asset('js/creer-sortie.js') }}"></script>
{% endblock %}