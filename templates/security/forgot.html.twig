{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/forgot.css">
{% endblock %}

{% block body %}
    <div class="page-container">
        <div class="content">
            <div class="forgot-container">
                <div class="forgot-card">
                    
                    <!-- Messages de succès -->
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success animate-slide-down">
                            <div class="alert-icon">✓</div>
                            <div class="alert-content">
                                <strong>Succès!</strong>
                                <p>{{ message }}</p>
                            </div>
                            <button type="button" class="alert-close" data-dismiss="alert">&times;</button>
                        </div>
                    {% endfor %}

                    <!-- Messages d'erreur -->
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger animate-slide-down">
                            <div class="alert-icon">!</div>
                            <div class="alert-content">
                                <strong>Erreur</strong>
                                <p>{{ message }}</p>
                            </div>
                            <button type="button" class="alert-close" data-dismiss="alert">&times;</button>
                        </div>
                    {% endfor %}

                    <div class="forgot-header">
                        <h2>Réinitialiser votre mot de passe</h2>
                        <p class="forgot-subtitle">Entrez votre email et votre téléphone pour réinitialiser votre mot de passe</p>
                    </div>

                    <form method="post" class="forgot-form">
                        {{ form_start(forgotForm) }}

                        <div class="form-group">
                            <label for="email" class="form-label">Email</label>
                            {{ form_widget(forgotForm.email, {
                                'attr': {
                                    'class': 'form-input',
                                    'placeholder': 'votre@email.com',
                                    'id': 'email'
                                }
                            }) }}
                            {% if forgotForm.email.vars.errors %}
                                <span class="error-message">
                                    {{ form_errors(forgotForm.email) }}
                                </span>
                            {% endif %}
                        </div>

                        <div class="form-group">
                            <label for="telephone" class="form-label">Numéro de téléphone</label>
                            {{ form_widget(forgotForm.telephone, {
                                'attr': {
                                    'class': 'form-input',
                                    'placeholder': '+33 6 12 34 56 78',
                                    'id': 'telephone'
                                }
                            }) }}
                            {% if forgotForm.telephone.vars.errors %}
                                <span class="error-message">
                                    {{ form_errors(forgotForm.telephone) }}
                                </span>
                            {% endif %}
                        </div>

                        <button type="submit" class="submit-btn">
                            <span>Réinitialiser mon mot de passe</span>
                            <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </button>

                        {{ form_end(forgotForm) }}

                        <div class="forgot-footer">
                            <p>Vous vous souvenez de votre mot de passe?</p>
                            <a href="{{ path('app_login') }}" class="back-link">Retourner à la connexion</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script type="module" src="{{ asset('js/forgot-message.js') }}"></script>
{% endblock %}
